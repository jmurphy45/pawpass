{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "./vendor/bin/sail pint --dirty"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "./vendor/bin/sail artisan test && ./vendor/bin/sail npm run build"
                    }
                ]
            }
        ]
    }
}
